NODE_ENV=development
APP_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
FRONTEND_ALLOWED_ORIGINS=http://localhost:3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/atur_gizi?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/atur_gizi?schema=public"

# Dev auth bypass when Kinde not configured (never enable in production)
AUTH_DEV_BYPASS=true
AUTH_DEV_USER_ID=dev-user-1
AUTH_DEV_EMAIL=dev@atur-gizi.local
AUTH_DEV_NAME=Dev User

KINDE_ISSUER_URL=
KINDE_AUDIENCE=
KINDE_JWKS_URL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=20000
GEMINI_MAX_RETRIES=2
AI_DAILY_QUOTA=10

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=ai-fitness/development
CLOUDINARY_DELIVERY_TYPE=authenticated

LOG_LEVEL=info
REQUEST_BODY_LIMIT=1mb
ACCOUNT_DELETION_RETENTION_DAYS=30
RAW_AI_RETENTION_DAYS=30
MIN_USER_AGE=15
