generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  active
  deletion_requested
  deleted
}

enum UnitSystem {
  metric
  imperial
}

enum MetabolicFormula {
  mifflin_a
  mifflin_b
  manual
}

enum ActivityLevel {
  sedentary
  light
  moderate
  high
  very_high
}

enum FitnessGoal {
  lose_weight
  maintain
  gain_weight
  manual
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
  other
}

enum FoodLogSource {
  manual
  ai_confirmed
  import
}

enum AiAnalysisStatus {
  uploaded
  processing
  succeeded
  needs_review
  confirmed
  failed
  cancelled
}

enum Intensity {
  low
  moderate
  high
}

enum ActivitySource {
  manual
  estimate
  device
}

enum CalorieBudgetMode {
  intake_only
  eat_back
}

enum BiologicalSex {
  male
  female
  unspecified
}

model AppUser {
  id           String     @id @default(uuid()) @db.Uuid
  kindeUserId  String     @unique @map("kinde_user_id")
  email        String?
  displayName  String?    @map("display_name")
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz

  profile         UserProfile?
  settings        UserSettings?
  dailyTargets    DailyTarget[]
  foodLogs        FoodLog[]
  activityLogs    ActivityLog[]
  weightLogs      WeightLog[]
  aiPortionBiases AiPortionBias[]
  energyState     UserEnergyState?
  aiAnalysisRuns  AiAnalysisRun[]
  auditEvents     AuditEvent[]
  idempotencyKeys IdempotencyKey[]
  aiUsageDaily    AiUsageDaily[]
  favoriteFoods   FavoriteFood[]
  favoriteActivities FavoriteActivity[]
  mealPlans       MealPlan[]
  barcodeScans    BarcodeScan[]
  wearableLinks   WearableLink[]
  socialPosts     SocialPost[]
  weeklyInsights  WeeklyInsight[]
  exportJobs      ExportJob[]
  subscriptions   Subscription[]
  rateLimitBuckets RateLimitBucket[]
  analyticsEvents AnalyticsEvent[]
  mealMemories    MealMemory[]

  @@map("app_users")
}

model MealMemory {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  alias       String
  resolvedName String  @map("resolved_name")
  portionAmount Decimal? @map("portion_amount") @db.Decimal(10, 2)
  portionUnit String?  @map("portion_unit")
  calories    Int?
  proteinG    Decimal? @map("protein_g") @db.Decimal(8, 2)
  carbsG      Decimal? @map("carbs_g") @db.Decimal(8, 2)
  fatG        Decimal? @map("fat_g") @db.Decimal(8, 2)
  notes       String?
  useCount    Int      @default(1) @map("use_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, alias])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("meal_memories")
}

model UserProfile {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @unique @map("user_id") @db.Uuid
  dateOfBirth         DateTime?        @map("date_of_birth") @db.Date
  heightCm            Decimal?         @map("height_cm") @db.Decimal(6, 2)
  currentWeightKg     Decimal?         @map("current_weight_kg") @db.Decimal(6, 2)
  sex                 BiologicalSex    @default(unspecified)
  metabolicFormula    MetabolicFormula @default(manual) @map("metabolic_formula")
  activityLevel       ActivityLevel?   @map("activity_level")
  fitnessGoal         FitnessGoal?     @map("fitness_goal")
  targetRate          Decimal?         @map("target_rate") @db.Decimal(5, 2)
  formulaVersion      String?          @map("formula_version")
  onboardingCompleted Boolean          @default(false) @map("onboarding_completed")
  estimatesAccepted   Boolean          @default(false) @map("estimates_accepted")
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSettings {
  id                String            @id @default(uuid()) @db.Uuid
  userId            String            @unique @map("user_id") @db.Uuid
  timezone          String            @default("Asia/Jakarta")
  unitSystem        UnitSystem        @default(metric) @map("unit_system")
  locale            String            @default("id-ID")
  retainFoodPhotos  Boolean           @default(false) @map("retain_food_photos")
  analyticsConsent  Boolean           @default(false) @map("analytics_consent")
  calorieBudgetMode CalorieBudgetMode @default(intake_only) @map("calorie_budget_mode")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model WeightLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  loggedAt  DateTime @map("logged_at") @db.Timestamptz
  weightKg  Decimal  @map("weight_kg") @db.Decimal(6, 2)
  note      String?
  source    String   @default("manual")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt(sort: Desc)])
  @@map("weight_logs")
}

model FoodReference {
  id             String   @id @default(uuid()) @db.Uuid
  slug           String   @unique
  name           String
  aliases        String[] @default([])
  portionAmount  Decimal  @default(1) @map("portion_amount") @db.Decimal(8, 2)
  portionUnit    String   @default("porsi") @map("portion_unit")
  refGrams       Decimal? @map("ref_grams") @db.Decimal(8, 2)
  caloriesPer100g Int?    @map("calories_per_100g")
  calories       Int
  proteinG       Decimal  @map("protein_g") @db.Decimal(8, 2)
  carbsG         Decimal  @map("carbs_g") @db.Decimal(8, 2)
  fatG           Decimal  @map("fat_g") @db.Decimal(8, 2)
  active         Boolean  @default(true)
  source         String   @default("catalog_id")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([name])
  @@map("food_references")
}

model AiPortionBias {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  foodKey           String   @map("food_key")
  sampleCount       Int      @default(0) @map("sample_count")
  medianKcalRatio   Decimal  @map("median_kcal_ratio") @db.Decimal(6, 3)
  medianAmountRatio Decimal? @map("median_amount_ratio") @db.Decimal(6, 3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, foodKey])
  @@index([userId])
  @@map("ai_portion_biases")
}

model UserEnergyState {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  adaptiveTdeeKcal Int?     @map("adaptive_tdee_kcal")
  suggestedTarget  Int?     @map("suggested_target")
  adjustmentKcal   Int?     @map("adjustment_kcal")
  method           String?  @default("weight_trend_v1")
  windowDays       Int?     @map("window_days")
  avgIntakeKcal    Int?     @map("avg_intake_kcal")
  weightSlopeKgWk  Decimal? @map("weight_slope_kg_wk") @db.Decimal(6, 3)
  inputs           Json?
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_energy_states")
}

model DailyTarget {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  effectiveFrom      DateTime     @map("effective_from") @db.Date
  effectiveTo        DateTime?    @map("effective_to") @db.Date
  bmrKcal            Int?         @map("bmr_kcal")
  tdeeKcal           Int?         @map("tdee_kcal")
  calorieTarget      Int          @map("calorie_target")
  proteinTargetG     Decimal?     @map("protein_target_g") @db.Decimal(8, 2)
  carbsTargetG       Decimal?     @map("carbs_target_g") @db.Decimal(8, 2)
  fatTargetG         Decimal?     @map("fat_target_g") @db.Decimal(8, 2)
  goal               FitnessGoal
  calculationMethod  String       @map("calculation_method")
  calculationInputs  Json         @map("calculation_inputs")
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, effectiveFrom(sort: Desc)])
  @@map("daily_targets")
}

model FoodLog {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  logDate            DateTime      @map("log_date") @db.Date
  consumedAt         DateTime      @map("consumed_at") @db.Timestamptz
  mealType           MealType      @map("meal_type")
  title              String
  totalCalories      Int           @map("total_calories")
  proteinG           Decimal?      @map("protein_g") @db.Decimal(8, 2)
  carbsG             Decimal?      @map("carbs_g") @db.Decimal(8, 2)
  fatG               Decimal?      @map("fat_g") @db.Decimal(8, 2)
  source             FoodLogSource @default(manual)
  cloudinaryPublicId String?       @map("cloudinary_public_id")
  mediaDeliveryType  String?       @map("media_delivery_type")
  aiAnalysisId       String?       @unique @map("ai_analysis_id") @db.Uuid
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?     @map("deleted_at") @db.Timestamptz

  user       AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      FoodItem[]
  aiAnalysis AiAnalysisRun? @relation(fields: [aiAnalysisId], references: [id])

  @@index([userId, logDate(sort: Desc), consumedAt(sort: Desc)])
  @@index([userId, logDate, deletedAt])
  @@map("food_logs")
}

model FoodItem {
  id            String   @id @default(uuid()) @db.Uuid
  foodLogId     String   @map("food_log_id") @db.Uuid
  name          String
  portionAmount Decimal  @map("portion_amount") @db.Decimal(10, 2)
  portionUnit   String   @map("portion_unit")
  calories      Int
  proteinG      Decimal? @map("protein_g") @db.Decimal(8, 2)
  carbsG        Decimal? @map("carbs_g") @db.Decimal(8, 2)
  fatG          Decimal? @map("fat_g") @db.Decimal(8, 2)
  fiberG        Decimal? @map("fiber_g") @db.Decimal(8, 2)
  aiConfidence  Decimal? @map("ai_confidence") @db.Decimal(4, 3)
  sortOrder     Int      @default(0) @map("sort_order")

  foodLog FoodLog @relation(fields: [foodLogId], references: [id], onDelete: Cascade)

  @@map("food_items")
}

model ActivityType {
  id         String   @id @default(uuid()) @db.Uuid
  slug       String   @unique
  name       String
  category   String
  defaultMet Decimal  @map("default_met") @db.Decimal(5, 2)
  active     Boolean  @default(true)
  sourceVersion String @default("met_compendium_v1") @map("source_version")

  logs ActivityLog[]

  @@map("activity_types")
}

model ActivityLog {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @map("user_id") @db.Uuid
  activityTypeId     String?        @map("activity_type_id") @db.Uuid
  customName         String?        @map("custom_name")
  logDate            DateTime       @map("log_date") @db.Date
  startedAt          DateTime?      @map("started_at") @db.Timestamptz
  durationMinutes    Int            @map("duration_minutes")
  intensity          Intensity      @default(moderate)
  metValue           Decimal        @map("met_value") @db.Decimal(5, 2)
  weightSnapshotKg   Decimal        @map("weight_snapshot_kg") @db.Decimal(6, 2)
  calculatedCalories Int            @map("calculated_calories")
  caloriesBurned     Int            @map("calories_burned")
  formulaVersion     String         @map("formula_version")
  notes              String?
  distanceM          Decimal?       @map("distance_m") @db.Decimal(10, 2)
  rpe                Int?
  avgHr              Int?           @map("avg_hr")
  sets               Int?
  reps               Int?
  loadKg             Decimal?       @map("load_kg") @db.Decimal(6, 2)
  source             ActivitySource @default(estimate)
  deviceCalories     Int?           @map("device_calories")
  metSource          String?        @map("met_source")
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?      @map("deleted_at") @db.Timestamptz

  user         AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityType ActivityType? @relation(fields: [activityTypeId], references: [id])

  @@index([userId, logDate(sort: Desc)])
  @@index([userId, logDate, deletedAt])
  @@map("activity_logs")
}

model AiAnalysisRun {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  provider            String           @default("google")
  model               String
  promptVersion       String           @map("prompt_version")
  schemaVersion       String           @map("schema_version")
  cloudinaryPublicId  String           @map("cloudinary_public_id")
  mediaDeliveryType   String?          @map("media_delivery_type")
  mediaVersion        String?          @map("media_version")
  mediaFormat         String?          @map("media_format")
  mediaBytes          Int?             @map("media_bytes")
  status              AiAnalysisStatus @default(uploaded)
  latencyMs           Int?             @map("latency_ms")
  overallConfidence   Decimal?         @map("overall_confidence") @db.Decimal(4, 3)
  normalizedOutput    Json?            @map("normalized_output")
  failureCode         String?          @map("failure_code")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz
  confirmedAt         DateTime?        @map("confirmed_at") @db.Timestamptz

  user    AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodLog FoodLog?

  @@index([userId, createdAt(sort: Desc)])
  @@map("ai_analysis_runs")
}

model AiUsageDaily {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  usageDate DateTime @map("usage_date") @db.Date
  count     Int      @default(0)

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, usageDate])
  @@map("ai_usage_daily")
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_events")
}

model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  key          String
  route        String
  requestHash  String   @map("request_hash")
  statusCode   Int      @map("status_code")
  responseBody Json     @map("response_body")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, route])
  @@map("idempotency_keys")
}

model FavoriteFood {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  name          String
  portionAmount Decimal  @map("portion_amount") @db.Decimal(10, 2)
  portionUnit   String   @map("portion_unit")
  calories      Int
  proteinG      Decimal? @map("protein_g") @db.Decimal(8, 2)
  carbsG        Decimal? @map("carbs_g") @db.Decimal(8, 2)
  fatG          Decimal? @map("fat_g") @db.Decimal(8, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("favorite_foods")
}

model FavoriteActivity {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  activityTypeId  String?  @map("activity_type_id") @db.Uuid
  customName      String?  @map("custom_name")
  defaultMinutes  Int      @default(30) @map("default_minutes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("favorite_activities")
}

model MealPlan {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  planDate    DateTime @map("plan_date") @db.Date
  mealType    MealType @map("meal_type")
  items       Json
  totalCalories Int    @map("total_calories")
  proteinG    Decimal? @map("protein_g") @db.Decimal(8, 2)
  carbsG      Decimal? @map("carbs_g") @db.Decimal(8, 2)
  fatG        Decimal? @map("fat_g") @db.Decimal(8, 2)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, planDate])
  @@map("meal_plans")
}

model BarcodeProduct {
  id               String    @id @default(uuid()) @db.Uuid
  barcode          String    @unique
  name             String
  brand            String?
  servingSize      String?   @map("serving_size")
  calories         Int
  proteinG         Decimal?  @map("protein_g") @db.Decimal(8, 2)
  carbsG           Decimal?  @map("carbs_g") @db.Decimal(8, 2)
  fatG             Decimal?  @map("fat_g") @db.Decimal(8, 2)
  nutrientBasis    String?   @map("nutrient_basis") // serving | 100g
  servingQuantityG Decimal?  @map("serving_quantity_g") @db.Decimal(8, 2)
  calories100g     Int?      @map("calories_100g")
  caloriesServing  Int?      @map("calories_serving")
  protein100g      Decimal?  @map("protein_100g") @db.Decimal(8, 2)
  carbs100g        Decimal?  @map("carbs_100g") @db.Decimal(8, 2)
  fat100g          Decimal?  @map("fat_100g") @db.Decimal(8, 2)
  proteinServing   Decimal?  @map("protein_serving") @db.Decimal(8, 2)
  carbsServing     Decimal?  @map("carbs_serving") @db.Decimal(8, 2)
  fatServing       Decimal?  @map("fat_serving") @db.Decimal(8, 2)
  source           String    @default("manual")
  fetchedAt        DateTime? @map("fetched_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  scans BarcodeScan[]

  @@map("barcode_products")
}

model BarcodeScan {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user    AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  product BarcodeProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("barcode_scans")
}

model WearableLink {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  provider     String
  externalId   String?  @map("external_id")
  status       String   @default("connected")
  lastSyncAt   DateTime? @map("last_sync_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("wearable_links")
}

model SocialPost {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String
  visibility String  @default("friends")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("social_posts")
}

model WeeklyInsight {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  weekStart    DateTime @map("week_start") @db.Date
  summary      Json
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@map("weekly_insights")
}

model ExportJob {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  format    String
  status    String   @default("ready")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("export_jobs")
}

model Subscription {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  plan             String   @default("free")
  status           String   @default("active")
  provider         String   @default("manual")
  externalId       String?  @map("external_id")
  currentPeriodEnd DateTime? @map("current_period_end") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model RateLimitBucket {
  id          String   @id @default(uuid()) @db.Uuid
  bucketKey   String   @map("bucket_key")
  routeKey    String   @map("route_key")
  windowStart DateTime @map("window_start") @db.Timestamptz
  count       Int      @default(0)
  userId      String?  @map("user_id") @db.Uuid

  user AppUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bucketKey, routeKey, windowStart])
  @@map("rate_limit_buckets")
}

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String
  props     Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("analytics_events")
}
